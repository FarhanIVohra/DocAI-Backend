# Backend Environment Variables (Required for DigitalOcean App Platform)

# Connects the backend to your running AI service (e.g., http://your-droplet-ip:8001/api/ai)
AI_SERVICE_URL=

# GitHub PAT for fetching PR diffs and publishing Gists
GITHUB_TOKEN=

# Redis (optional, DigitalOcean App Platform provides one internally if configured)
REDIS_URL=redis://localhost:6379/0

# SQLite fallback path
DATABASE_URL=sqlite:///./autodoc_v2.db
